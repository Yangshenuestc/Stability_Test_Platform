<Window
    x:Class="Stability_Test_Platform.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="HM Lab"
    Width="1920"
    Height="1080"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <Style x:Key="TopLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#7A8599" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SidebarMenuItemStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="50" />
            <Setter Property="Margin" Value="10,5,10,5" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="border"
                            Padding="20,0"
                            Background="Transparent"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F5F7FA" />
                                <Setter Property="Foreground" Value="#0066FF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E6F0FF" />
                                <Setter Property="Foreground" Value="#0066FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="#F8FAFC"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0066FF" />
                                <Setter Property="Background" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Background" Value="#F8FAFC" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0.0" Color="OrangeRed" />
                        <GradientStop Offset="1.0" Color="Orange" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0.0" Color="DarkRed" />
                                            <GradientStop Offset="1.0" Color="Red" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataCardStyle" TargetType="ContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Grid>
                            <Border
                                Background="White"
                                BorderBrush="#EAEAEA"
                                BorderThickness="1"
                                CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="12"
                                        Opacity="0.04"
                                        ShadowDepth="4"
                                        Color="#000000" />
                                </Border.Effect>
                            </Border>
                            <Border
                                Padding="{TemplateBinding Padding}"
                                Background="White"
                                BorderBrush="#EAEAEA"
                                BorderThickness="1"
                                CornerRadius="12"
                                RenderOptions.ClearTypeHint="Enabled">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GraphPlaceholderStyle" TargetType="ContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Grid>
                            <Border
                                Background="White"
                                BorderBrush="#EAEAEA"
                                BorderThickness="1"
                                CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="15"
                                        Opacity="0.06"
                                        ShadowDepth="5"
                                        Color="#000000" />
                                </Border.Effect>
                            </Border>
                            <Border
                                Padding="{TemplateBinding Padding}"
                                Background="White"
                                BorderBrush="#EAEAEA"
                                BorderThickness="1"
                                CornerRadius="12"
                                RenderOptions.ClearTypeHint="Enabled">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="25,15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border
                            x:Name="Border"
                            Margin="5,0"
                            Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            BorderThickness="0,0,0,3">
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0066FF" />
                                <Setter Property="Foreground" Value="#0066FF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="Foreground" Value="#444444" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTabControlStyle" TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                x:Name="TabHeaderArea"
                                Grid.Row="0"
                                Padding="15,0"
                                Background="Transparent">
                                <TabPanel IsItemsHost="True" />
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ModernTabItemStyle}" />
        </Style>

        <Style x:Key="ModernRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,30,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <BulletDecorator Background="Transparent" Cursor="Hand">
                            <BulletDecorator.Bullet>
                                <Grid Width="18" Height="18">
                                    <Ellipse
                                        x:Name="BorderEllipse"
                                        Fill="White"
                                        Stroke="#B0B0B0"
                                        StrokeThickness="1.5" />
                                    <Ellipse
                                        x:Name="CheckEllipse"
                                        Width="10"
                                        Height="10"
                                        Fill="#0066FF"
                                        Visibility="Collapsed" />
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BorderEllipse" Property="Stroke" Value="#0066FF" />
                                <Setter TargetName="CheckEllipse" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderEllipse" Property="Stroke" Value="#0066FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeviceToggleStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border
                                x:Name="border"
                                Background="#F4F5F7"
                                CornerRadius="6"
                                RenderOptions.ClearTypeHint="Enabled">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="4"
                                        Opacity="0.1"
                                        ShadowDepth="1"
                                        Color="#000000" />
                                </Border.Effect>
                                <TextBlock
                                    x:Name="txt"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="22"
                                    FontWeight="Medium"
                                    Foreground="#334155"
                                    Text="{TemplateBinding Content}" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1890FF" />
                                <Setter TargetName="txt" Property="Foreground" Value="White" />
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IdlePanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTesting}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TestingPanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTesting}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F4F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Panel.ZIndex="10">
            <Border Background="White">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="8"
                        Direction="270"
                        Opacity="0.05"
                        ShadowDepth="2"
                        Color="#000000" />
                </Border.Effect>
            </Border>
            <Border
                Padding="25,0"
                Background="White"
                RenderOptions.ClearTypeHint="Enabled">
                <DockPanel VerticalAlignment="Center">
                    <Image
                        Width="45"
                        Height="45"
                        Margin="0,0,15,0"
                        DockPanel.Dock="Left"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Source="/Image/HM Lab.png"
                        Stretch="Uniform" />
                    <TextBlock
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="#1A1A1A"
                        Text="HM Lab Stability Testing Platform" />
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,1,0,0">
                <Border Background="White">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="10"
                            Direction="0"
                            Opacity="0.05"
                            ShadowDepth="3"
                            Color="#000000" />
                    </Border.Effect>
                </Border>
                <Border Background="White" RenderOptions.ClearTypeHint="Enabled">
                    <StackPanel Margin="0,20,0,0">
                        <RadioButton
                            x:Name="MenuStabilityTest"
                            Content="Stability Testing"
                            GroupName="SidebarMenu"
                            IsChecked="True"
                            Style="{StaticResource SidebarMenuItemStyle}" />
                        <RadioButton
                            x:Name="MenuStabilityPrediction"
                            Content="Stability Prediction"
                            GroupName="SidebarMenu"
                            Style="{StaticResource SidebarMenuItemStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="1" Margin="20,20,20,20">
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=MenuStabilityTest}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <TabControl
                        Background="Transparent"
                        BorderThickness="0"
                        DisplayMemberPath="CavityName"
                        ItemsSource="{Binding Cavitys}"
                        SelectedItem="{Binding SelectedCavity}"
                        Style="{StaticResource ModernTabControlStyle}">
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="460" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Border Background="White" CornerRadius="12">
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="15"
                                                    Opacity="0.05"
                                                    ShadowDepth="5"
                                                    Color="#000000" />
                                            </Border.Effect>
                                        </Border>
                                        <Border
                                            Padding="30"
                                            Background="White"
                                            CornerRadius="12"
                                            RenderOptions.ClearTypeHint="Enabled">
                                            <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Top">

                                                <StackPanel>
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                    <Setter Property="Opacity" Value="0.6" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>

                                                    <StackPanel Margin="0,0,0,20">
                                                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                                            <Button
                                                                Width="80"
                                                                Height="34"
                                                                Background="#1E293B"
                                                                Command="{Binding SelectPathCommand}"
                                                                Content="Path"
                                                                Cursor="Hand"
                                                                FontWeight="Bold"
                                                                Foreground="White">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                            <TextBlock
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                Text="{TemplateBinding Content}" />
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                            <TextBlock
                                                                MaxWidth="280"
                                                                Margin="15,0,0,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="14"
                                                                Foreground="{Binding PathColor}"
                                                                Text="{Binding SavePath}"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Margin="0,0,0,20">
                                                        <TextBlock Style="{StaticResource TopLabelStyle}" Text="File Name" />
                                                        <TextBox
                                                            Foreground="{Binding PathColor}"
                                                            IsReadOnly="True"
                                                            Text="{Binding FileName}" />
                                                    </StackPanel>

                                                    <Grid Margin="0,0,0,20">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="20" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Style="{StaticResource TopLabelStyle}" Text="Device Type" />
                                                            <StackPanel
                                                                Height="38"
                                                                VerticalAlignment="Center"
                                                                Orientation="Horizontal">
                                                                <RadioButton
                                                                    Margin="0,0,15,0"
                                                                    Content="N-I-P"
                                                                    IsChecked="{Binding IsFormalType}"
                                                                    Style="{StaticResource ModernRadioButtonStyle}" />
                                                                <RadioButton
                                                                    Content="P-I-N"
                                                                    IsChecked="{Binding IsInvertedType}"
                                                                    Style="{StaticResource ModernRadioButtonStyle}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Style="{StaticResource TopLabelStyle}" Text="Area (cm²)" />
                                                            <TextBox Text="{Binding DeviceArea}" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,20">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="20" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Style="{StaticResource TopLabelStyle}" Text="Initial Voltage (V)" />
                                                            <TextBox Text="{Binding InitialVoltage}" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Style="{StaticResource TopLabelStyle}" Text="Terminal Voltage (V)" />
                                                            <TextBox Text="{Binding TerminalVoltage}" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,20">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="20" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Style="{StaticResource TopLabelStyle}" Text="Voltage Step (V)" />
                                                            <TextBox Text="{Binding VoltageStep}" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Style="{StaticResource TopLabelStyle}" Text="Applied Bias (V)" />
                                                            <TextBox Text="{Binding AppliedVoltage}" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <StackPanel Margin="0,0,0,20">
                                                        <TextBlock Style="{StaticResource TopLabelStyle}" Text="Test Mode" />
                                                        <ComboBox SelectedValue="{Binding SelectedTestMode}" SelectedValuePath="Content">
                                                            <ComboBoxItem Content="ISOS-LC-1/2" />
                                                            <ComboBoxItem Content="ISOS-L-1" />
                                                            <ComboBoxItem Content="ISOS-L-2" />
                                                        </ComboBox>
                                                    </StackPanel>

                                                    <ContentControl IsEnabled="{Binding HasTestMode}">
                                                        <ContentControl.Style>
                                                            <Style TargetType="ContentControl">
                                                                <Setter Property="Content" Value="Select test mode above to set conditions..." />
                                                                <Setter Property="Foreground" Value="#AAAAAA" />
                                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                                <Setter Property="FontSize" Value="14" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SelectedTestMode}" Value="ISOS-LC-1/2">
                                                                        <Setter Property="ContentTemplate">
                                                                            <Setter.Value>
                                                                                <DataTemplate>
                                                                                    <StackPanel>
                                                                                        <Grid Margin="0,0,0,10">
                                                                                            <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="*" />
                                                                                                <ColumnDefinition Width="20" />
                                                                                                <ColumnDefinition Width="*" />
                                                                                            </Grid.ColumnDefinitions>
                                                                                            <StackPanel Grid.Column="0">
                                                                                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Light Time (h)" />
                                                                                                <TextBox Text="{Binding LightTime}" />
                                                                                            </StackPanel>
                                                                                            <StackPanel Grid.Column="2">
                                                                                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Dark Time (h)" />
                                                                                                <TextBox Text="{Binding DarkTime}" />
                                                                                            </StackPanel>
                                                                                        </Grid>
                                                                                        <TextBlock
                                                                                            Margin="0,5,0,0"
                                                                                            FontSize="13"
                                                                                            FontWeight="SemiBold"
                                                                                            Foreground="#107C10"
                                                                                            Text="* Room Temp Default" />
                                                                                    </StackPanel>
                                                                                </DataTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding SelectedTestMode}" Value="ISOS-L-1">
                                                                        <Setter Property="ContentTemplate">
                                                                            <Setter.Value>
                                                                                <DataTemplate>
                                                                                    <StackPanel>
                                                                                        <TextBlock Style="{StaticResource TopLabelStyle}" Text="Target Temperature (℃)" />
                                                                                        <TextBox Text="{Binding TargetTemperature}" />
                                                                                    </StackPanel>
                                                                                </DataTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding SelectedTestMode}" Value="ISOS-L-2">
                                                                        <Setter Property="ContentTemplate">
                                                                            <Setter.Value>
                                                                                <DataTemplate>
                                                                                    <StackPanel>
                                                                                        <Grid Margin="0,0,0,20">
                                                                                            <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="*" />
                                                                                                <ColumnDefinition Width="20" />
                                                                                                <ColumnDefinition Width="*" />
                                                                                            </Grid.ColumnDefinitions>
                                                                                            <StackPanel Grid.Column="0">
                                                                                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Low Temp (℃)" />
                                                                                                <TextBox Text="{Binding CycleLowTemperature}" />
                                                                                            </StackPanel>
                                                                                            <StackPanel Grid.Column="2">
                                                                                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="High Temp (℃)" />
                                                                                                <TextBox Text="{Binding CycleHighTemperature}" />
                                                                                            </StackPanel>
                                                                                        </Grid>
                                                                                        <Grid>
                                                                                            <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="*" />
                                                                                                <ColumnDefinition Width="20" />
                                                                                                <ColumnDefinition Width="*" />
                                                                                            </Grid.ColumnDefinitions>
                                                                                            <StackPanel Grid.Column="0">
                                                                                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Heat Time (h)" />
                                                                                                <TextBox Text="{Binding HeatingTime}" />
                                                                                            </StackPanel>
                                                                                            <StackPanel Grid.Column="2">
                                                                                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Cool Time (h)" />
                                                                                                <TextBox Text="{Binding CoolingTime}" />
                                                                                            </StackPanel>
                                                                                        </Grid>
                                                                                    </StackPanel>
                                                                                </DataTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContentControl.Style>
                                                    </ContentControl>
                                                </StackPanel>
                                                <Button
                                                    Height="48"
                                                    Margin="0,35,0,0"
                                                    BorderThickness="0"
                                                    Command="{Binding StartTestCommand}"
                                                    Cursor="Hand"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Foreground="White">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="IsEnabled" Value="{Binding HasTestMode}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Button.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Offset="0.0" Color="Green" />
                                                            <GradientStop Offset="1.0" Color="LightGreen" />
                                                        </LinearGradientBrush>
                                                    </Button.Background>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border
                                                                x:Name="border"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="6">
                                                                <StackPanel
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Orientation="Horizontal">
                                                                    <TextBlock
                                                                        x:Name="txt"
                                                                        VerticalAlignment="Center"
                                                                        Text="Start Testing" />
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background">
                                                                        <Setter.Value>
                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                <GradientStop Offset="0.0" Color="DarkGreen" />
                                                                                <GradientStop Offset="1.0" Color="MediumSeaGreen" />
                                                                            </LinearGradientBrush>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="border" Property="Background" Value="#E2E8F0" />
                                                                    <Setter TargetName="txt" Property="Foreground" Value="#94A3B8" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Column="2">
                                        <Border Background="White" CornerRadius="12">
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="15"
                                                    Opacity="0.05"
                                                    ShadowDepth="5"
                                                    Color="#000000" />
                                            </Border.Effect>
                                        </Border>
                                        <Border
                                            Padding="25"
                                            Background="White"
                                            CornerRadius="12"
                                            RenderOptions.ClearTypeHint="Enabled">
                                            <Grid>
                                                <Grid Style="{StaticResource IdlePanelStyle}">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock
                                                            Margin="0,0,0,20"
                                                            HorizontalAlignment="Center"
                                                            FontSize="80"
                                                            Foreground="#E0E0E0"
                                                            Text="📈" />
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            FontSize="20"
                                                            FontWeight="Bold"
                                                            Foreground="#B0B0B0"
                                                            Text="Ready to execute analysis..." />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Style="{StaticResource TestingPanelStyle}">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>

                                                    <Grid Margin="0,0,0,15">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="15" />
                                                            <ColumnDefinition Width="1.2*" />
                                                            <ColumnDefinition Width="15" />
                                                            <ColumnDefinition Width="1.5*" />
                                                        </Grid.ColumnDefinitions>

                                                        <ContentControl
                                                            Grid.Column="0"
                                                            Height="85"
                                                            Padding="15,10"
                                                            Style="{StaticResource DataCardStyle}">
                                                            <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>
                                                                <TextBlock
                                                                    Grid.Row="0"
                                                                    FontSize="13"
                                                                    FontWeight="Bold"
                                                                    Foreground="#888888"
                                                                    Text="Temperature" />
                                                                <StackPanel
                                                                    Grid.Row="1"
                                                                    VerticalAlignment="Bottom"
                                                                    Orientation="Horizontal">
                                                                    <TextBlock
                                                                        VerticalAlignment="Bottom"
                                                                        FontSize="30"
                                                                        FontWeight="Bold"
                                                                        Foreground="#FF5722"
                                                                        Text="{Binding CurrentTemperature, StringFormat={}{0:F1}}" />
                                                                    <TextBlock
                                                                        Margin="3,0,0,5"
                                                                        VerticalAlignment="Bottom"
                                                                        FontSize="16"
                                                                        FontWeight="Bold"
                                                                        Foreground="#A0A0A0"
                                                                        Text="℃" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </ContentControl>

                                                        <ContentControl
                                                            Grid.Column="2"
                                                            Height="85"
                                                            Padding="15,10"
                                                            Style="{StaticResource DataCardStyle}">
                                                            <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>
                                                                <TextBlock
                                                                    Grid.Row="0"
                                                                    FontSize="13"
                                                                    FontWeight="Bold"
                                                                    Foreground="#888888"
                                                                    Text="Operating Time" />
                                                                <StackPanel
                                                                    Grid.Row="1"
                                                                    VerticalAlignment="Bottom"
                                                                    Orientation="Horizontal">
                                                                    <TextBlock
                                                                        VerticalAlignment="Bottom"
                                                                        FontSize="30"
                                                                        FontWeight="Bold"
                                                                        Foreground="#007BFF"
                                                                        Text="{Binding RunningTime, StringFormat={}{0:hh\\:mm\\:ss}}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </ContentControl>

                                                        <ContentControl
                                                            Grid.Column="4"
                                                            Height="85"
                                                            Padding="15,10"
                                                            Style="{StaticResource DataCardStyle}">
                                                            <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>
                                                                <TextBlock
                                                                    Grid.Row="0"
                                                                    FontSize="13"
                                                                    FontWeight="Bold"
                                                                    Foreground="#888888"
                                                                    Text="T80 Alert Status" />
                                                                <StackPanel
                                                                    Grid.Row="1"
                                                                    Margin="0,0,0,4"
                                                                    VerticalAlignment="Bottom"
                                                                    Orientation="Horizontal">
                                                                    <Ellipse
                                                                        Width="14"
                                                                        Height="14"
                                                                        Margin="0,0,8,0"
                                                                        VerticalAlignment="Center"
                                                                        Fill="{Binding T80WarningColor}" />
                                                                    <TextBlock
                                                                        VerticalAlignment="Center"
                                                                        FontSize="16"
                                                                        FontWeight="Bold"
                                                                        Foreground="#333333"
                                                                        Text="{Binding T80StatusText}"
                                                                        TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </ContentControl>
                                                    </Grid>

                                                    <Grid Grid.Row="1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <ContentControl
                                                            Grid.Column="0"
                                                            Margin="0,0,15,0"
                                                            Padding="15"
                                                            Style="{StaticResource DataCardStyle}">
                                                            <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <TextBlock
                                                                    Margin="0,0,0,10"
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="14"
                                                                    FontWeight="Bold"
                                                                    Foreground="#444444"
                                                                    Text="Device Selection"
                                                                    TextAlignment="Center" />

                                                                <StackPanel
                                                                    Grid.Row="1"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Orientation="Vertical">
                                                                    <Border
                                                                        Margin="0,0,0,10"
                                                                        Padding="10"
                                                                        Background="LightBlue"
                                                                        CornerRadius="6">
                                                                        <UniformGrid Columns="3" Rows="3">
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Left - Device 1"
                                                                                Content="1"
                                                                                GroupName="{Binding CavityName}"
                                                                                IsChecked="True"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Left - Device 2"
                                                                                Content="2"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Left - Device 3"
                                                                                Content="3"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Left - Device 4"
                                                                                Content="4"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Left - Device 5"
                                                                                Content="5"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Left - Device 6"
                                                                                Content="6"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Left - Device 7"
                                                                                Content="7"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Left - Device 8"
                                                                                Content="8"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Left - Device 9"
                                                                                Content="9"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                        </UniformGrid>
                                                                    </Border>

                                                                    <Border
                                                                        Padding="10"
                                                                        Background="LightBlue"
                                                                        CornerRadius="6">
                                                                        <UniformGrid Columns="3" Rows="3">
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Right - Device 1"
                                                                                Content="1"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Right - Device 2"
                                                                                Content="2"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Right - Device 3"
                                                                                Content="3"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Right - Device 4"
                                                                                Content="4"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Right - Device 5"
                                                                                Content="5"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Right - Device 6"
                                                                                Content="6"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Right - Device 7"
                                                                                Content="7"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Right - Device 8"
                                                                                Content="8"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                            <RadioButton
                                                                                Command="{Binding SelectDeviceCommand}"
                                                                                CommandParameter="Right - Device 9"
                                                                                Content="9"
                                                                                GroupName="{Binding CavityName}"
                                                                                Style="{StaticResource DeviceToggleStyle}" />
                                                                        </UniformGrid>
                                                                    </Border>
                                                                </StackPanel>

                                                                <Button
                                                                    Grid.Row="2"
                                                                    Width="140"
                                                                    Height="45"
                                                                    Margin="0,20,0,0"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Command="{Binding StopTestCommand}"
                                                                    Content="Stop testing"
                                                                    Style="{StaticResource DangerButtonStyle}" />
                                                            </Grid>
                                                        </ContentControl>

                                                        <ContentControl
                                                            Grid.Column="1"
                                                            Padding="20"
                                                            Style="{StaticResource GraphPlaceholderStyle}">
                                                            <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>

                                                                <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                                                                    <TextBlock
                                                                        FontSize="15"
                                                                        FontWeight="Bold"
                                                                        Foreground="#444444"
                                                                        Text="Real-time Graph - " />
                                                                    <TextBlock
                                                                        FontSize="15"
                                                                        FontWeight="Bold"
                                                                        Foreground="#007BFF"
                                                                        Text="{Binding SelectedDeviceTitle}" />
                                                                </StackPanel>

                                                                <TextBlock
                                                                    Grid.Row="1"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="20"
                                                                    FontWeight="Bold"
                                                                    Foreground="#B0B0B0"
                                                                    Text="待测量获取" />
                                                            </Grid>
                                                        </ContentControl>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=MenuStabilityPrediction}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid Margin="0,10,0,0">
                        <Border Background="White" CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="15"
                                    Opacity="0.05"
                                    ShadowDepth="5"
                                    Color="#000000" />
                            </Border.Effect>
                        </Border>
                        <Border
                            Padding="40"
                            Background="White"
                            CornerRadius="12"
                            RenderOptions.ClearTypeHint="Enabled">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock
                                    Margin="0,0,0,20"
                                    HorizontalAlignment="Center"
                                    FontSize="60"
                                    Text="🤖" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Foreground="#333333"
                                    Text="AI Stability Prediction Model" />
                                <TextBlock
                                    Margin="0,15,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    Foreground="#888888"
                                    Text="钙钛矿寿命预测大模型模块，即将上线..." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>